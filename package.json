{
	"name": "lint-wiki-dumps",
	"version": "0.11.0",
	"description": "Lint Wikipedia dumps",
	"keywords": [
		"lint",
		"wikipedia"
	],
	"homepage": "https://github.com/bhsd-harry/lint-wiki-dumps#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/lint-wiki-dumps/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"*.sh",
		"!bump.sh",
		"!scan-toolforge.sh",
		"*.js",
		"!server.js",
		"!config.js",
		"config/",
		"reports/*.html",
		"reports/dist/*.js",
		"reports/*.css"
	],
	"bin": {
		"lint-wiki-dumps": "scan.sh"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/lint-wiki-dumps.git"
	},
	"scripts": {
		"ls": "npm i --package-lock-only && npm ls --package-lock-only --all --omit=dev",
		"start": "node server.js",
		"prepublishOnly": "npm run build",
		"bundle": "esbuild reports/src/*.ts --charset=utf8 --bundle --format=esm --outdir=build && rm build/common.js",
		"build": "tsc && mv dist/* . && npm run bundle && esbuild reports/src/*.ts --charset=utf8 --bundle --minify --target=es2019 --format=iife --sourcemap --outdir=reports/dist && rm reports/dist/common.js*",
		"lint:ts": "tsc --noEmit && tsc --project reports/tsconfig.json --noEmit && eslint --cache .",
		"lint:css": "stylelint --cache reports/*.css",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:css && npm run lint:md",
		"toolforge": "bash scan-toolforge.sh"
	},
	"peerDependencies": {
		"htmlparser2": ">=10.0.0",
		"mariadb": ">=3.0.0",
		"vscode-css-languageservice": ">=3.0.0"
	},
	"peerDependenciesMeta": {
		"htmlparser2": {
			"optional": true
		},
		"mariadb": {
			"optional": true
		},
		"vscode-css-languageservice": {
			"optional": true
		}
	},
	"dependencies": {
		"@bhsd/nodejs": "^1.0.1",
		"wikilint": "^2.43.0"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^2.6.2",
		"esbuild": "^0.28.0",
		"eslint": "^10.4.1",
		"htmlparser2": "^12.0.0",
		"mariadb": "^3.5.2",
		"markdownlint-cli2": "^0.22.1",
		"stylelint": "^17.13.0",
		"typescript": "^6.0.3",
		"vscode-css-languageservice": "^6.3.10"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0 || >=24.11.0"
	}
}
