{
	"name": "lint-wiki-dumps",
	"version": "0.9.1",
	"description": "Lint Wikipedia dumps",
	"keywords": [
		"lint",
		"wikipedia"
	],
	"homepage": "https://github.com/bhsd-harry/lint-wiki-dumps#readme",
	"bugs": {
		"url": "https://github.com/bhsd-harry/lint-wiki-dumps/issues"
	},
	"license": "GPL-3.0-or-later",
	"author": "Bhsd",
	"files": [
		"*.sh",
		"!bump.sh",
		"!scan-toolforge.sh",
		"*.js",
		"!server.js",
		"!config.js",
		"config/",
		"reports/*.html",
		"reports/dist/*.js",
		"reports/*.css"
	],
	"bin": {
		"lint-wiki-dumps": "scan.sh"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bhsd-harry/lint-wiki-dumps.git"
	},
	"scripts": {
		"start": "node server.js",
		"prepublishOnly": "npm run build",
		"bundle": "esbuild reports/src/*.ts --charset=utf8 --bundle --format=esm --outdir=build && rm build/common.js",
		"build": "tsc && mv dist/* . && npm run bundle && esbuild reports/src/*.ts --charset=utf8 --bundle --minify --target=es2019 --format=iife --sourcemap --outdir=reports/dist && rm reports/dist/common.js*",
		"lint:ts": "tsc --noEmit && tsc --project reports/tsconfig.json --noEmit && eslint --flag v10_config_lookup_from_file --cache .",
		"lint:css": "stylelint **/*.css",
		"lint:md": "markdownlint-cli2 '**/*.md'",
		"lint": "npm run lint:ts && npm run lint:css && npm run lint:md",
		"toolforge": "bash scan-toolforge.sh"
	},
	"dependencies": {
		"@bhsd/nodejs": "^0.1.1",
		"unbzip2-stream": "^1.4.3",
		"wikilint": "^2.36.0",
		"xml-stream": "^0.4.5"
	},
	"optionalDependencies": {
		"vscode-css-languageservice": "^6.3.10"
	},
	"devDependencies": {
		"@bhsd/code-standard": "^2.1.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@stylistic/stylelint-plugin": "^5.0.1",
		"@types/node": "^24.11.0",
		"@types/unbzip2-stream": "^1.4.3",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"esbuild": "^0.27.4",
		"eslint": "^9.39.4",
		"eslint-plugin-es-x": "^9.5.0",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-jsdoc": "^62.7.1",
		"eslint-plugin-jsonc": "^3.1.1",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-regexp": "^3.1.0",
		"eslint-plugin-unicorn": "^63.0.0",
		"mariadb": "^3.5.2",
		"markdownlint-cli2": "^0.21.0",
		"stylelint": "^17.5.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-plugin-use-baseline": "^1.2.7",
		"typescript": "^5.9.3"
	},
	"engines": {
		"node": "^20.19.0 || ^22.13.0"
	}
}
